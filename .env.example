# Proveedor del LLM principal: "gemini" (default), "openai" u "ollama"
LLM_PROVIDER=gemini

# Gemini (Google AI Studio: https://aistudio.google.com/app/apikey)
# Modelos sugeridos (en orden de preferencia, cualquiera que tenga cuota libre sirve):
#   gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-flash-lite
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (solo si LLM_PROVIDER=openai)
# Crea una key en https://platform.openai.com/api-keys
# Modelos sugeridos: gpt-4o-mini (recomendado), gpt-4o, gpt-4.1-mini
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama (solo si LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# LangSmith (opcional, para tracing en desarrollo)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ecomarket-agent
